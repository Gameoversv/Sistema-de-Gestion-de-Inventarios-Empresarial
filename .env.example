# ============================================================
# Sistema de Gestión de Inventarios — Variables de Entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA commitees el archivo .env con valores reales.
# ============================================================

# ---- Base de Datos (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_db
DB_USER=inventory_user
DB_PASSWORD=changeme_db_password

# ---- Cache (Redis) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Backend (Spring Boot) ----
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=changeme_jwt_secret_min_32_chars
JWT_EXPIRATION_MS=86400000

# ---- Frontend (React) ----
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080/api/v1

# ---- Observabilidad ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# ---- Logs ----
LOG_LEVEL=INFO

# ---- Entorno ----
# Valores: dev | test | staging | prod
APP_ENV=dev
