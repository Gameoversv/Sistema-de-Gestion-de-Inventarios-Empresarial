# ============================================================
# Sistema de Gestión de Inventarios — Variables de Entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA commitees el archivo .env con valores reales.
# ============================================================

# ---- Base de Datos (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory_db
DB_USER=inventory_user
DB_PASSWORD=changeme_db_password

# ---- Cache (Redis) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# ---- Backend (Spring Boot) ----
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ---- Frontend (React) ----
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080

# ---- Observabilidad ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password
TEMPO_PORT=3200
LOKI_PORT=3100
ALLOY_PORT=12345
ALERTMANAGER_PORT=9093

# ---- Logs ----
LOG_LEVEL=INFO
# El JSON estructurado con traceId/spanId/correlationId/usuario/endpoint solo se
# emite en los perfiles staging y prod. En dev los logs son texto legible.

# ---- Keycloak ----
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak_admin
KC_DB_NAME=keycloak_db
KC_DB_USER=keycloak_user
KC_DB_PASSWORD=changeme_kc_db_password
KC_REALM=inventory

# ---- Keycloak Test Users (solo dev/test) ----
KC_USER_ADMIN_USERNAME=inv_admin
KC_USER_ADMIN_PASSWORD=changeme_admin_pass
KC_USER_CLERK_USERNAME=inv_clerk
KC_USER_CLERK_PASSWORD=changeme_clerk_pass
KC_USER_AUDITOR_USERNAME=inv_auditor
KC_USER_AUDITOR_PASSWORD=changeme_auditor_pass
KC_USER_VIEWER_USERNAME=inv_viewer
KC_USER_VIEWER_PASSWORD=changeme_viewer_pass

# ---- Entorno ----
# Valores: dev | test | staging | prod
APP_ENV=dev
