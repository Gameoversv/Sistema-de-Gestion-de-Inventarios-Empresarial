    {
      "name": "Error Responses (RFC 7807)",
      "description": "Ejemplos de respuestas de error en formato Problem Details (RFC 7807). Todos los errores siguen la estructura: type, title, status, detail, instance.",
      "item": [
        {
          "name": "404 - Producto no encontrado",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/999999",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "999999"
              ]
            }
          },
          "response": [
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"type\": \"https://inventory.api/problems/not-found\",\n  \"title\": \"Resource Not Found\",\n  \"status\": 404,\n  \"detail\": \"Product not found: 999999\",\n  \"instance\": \"/api/v1/products/999999\"\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 404', () => pm.response.to.have.status(404));",
                  "pm.test('error body has status 404 and detail', () => { const b = pm.response.json(); pm.expect(b).to.have.property('status'); pm.expect(b).to.have.property('detail'); pm.expect(b.status).to.equal(404); });"
                ]
              }
            }
          ]
