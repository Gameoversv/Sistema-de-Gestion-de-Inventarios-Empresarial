{
  "info": {
    "name": "Inventory API",
    "description": "Sistema de Gestión de Inventarios Empresarial — colección completa de endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "inventory-api-v1"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "<JWT_TOKEN>",
      "type": "string",
      "description": "Bearer token obtenido de Keycloak"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Listar categorías",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/categories",
              "host": ["{{baseUrl}}"],
              "path": ["categories"]
            }
          },
          "response": []
        },
        {
          "name": "Obtener categoría por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/categories/1",
              "host": ["{{baseUrl}}"],
              "path": ["categories", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Crear categoría",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic products and accessories\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/categories",
              "host": ["{{baseUrl}}"],
              "path": ["categories"]
            }
          },
          "response": []
        },
        {
          "name": "Actualizar categoría",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Consumer Electronics\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/categories/1",
              "host": ["{{baseUrl}}"],
              "path": ["categories", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Eliminar categoría",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/categories/1",
              "host": ["{{baseUrl}}"],
              "path": ["categories", "1"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Listar productos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?page=0&size=20&sort=name",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "name" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "categoryId", "value": "", "disabled": true },
                { "key": "active", "value": "true", "disabled": true }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Obtener producto por ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/1",
              "host": ["{{baseUrl}}"],
              "path": ["products", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Crear producto",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"LAP-001\",\n  \"name\": \"Laptop Pro 15\",\n  \"description\": \"High-performance laptop\",\n  \"price\": 1299.99,\n  \"stock\": 50,\n  \"minimumStock\": 5,\n  \"active\": true,\n  \"categoryId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          },
          "response": []
        },
        {
          "name": "Actualizar producto (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"LAP-001\",\n  \"name\": \"Laptop Pro 15 v2\",\n  \"description\": \"Updated description\",\n  \"price\": 1199.99,\n  \"stock\": 45,\n  \"minimumStock\": 5,\n  \"active\": true,\n  \"categoryId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/1",
              "host": ["{{baseUrl}}"],
              "path": ["products", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Actualización parcial de producto (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 999.99,\n  \"stock\": 30\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/1",
              "host": ["{{baseUrl}}"],
              "path": ["products", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Desactivar producto (soft delete)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/products/1",
              "host": ["{{baseUrl}}"],
              "path": ["products", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Buscar productos por nombre/SKU",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?search=laptop&page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "search", "value": "laptop" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Filtrar productos por categoría",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?categoryId=1&active=true&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "categoryId", "value": "1" },
                { "key": "active", "value": "true" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Error Responses (RFC 7807)",
      "description": "Ejemplos de respuestas de error en formato Problem Details (RFC 7807). Todos los errores siguen la estructura: type, title, status, detail, instance.",
      "item": [
        {
          "name": "404 - Producto no encontrado",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/999999",
              "host": ["{{baseUrl}}"],
              "path": ["products", "999999"]
            }
          },
          "response": [
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"type\": \"https://inventory.api/problems/not-found\",\n  \"title\": \"Resource Not Found\",\n  \"status\": 404,\n  \"detail\": \"Product not found: 999999\",\n  \"instance\": \"/api/v1/products/999999\"\n}"
            }
          ]
        },
        {
          "name": "409 - SKU duplicado",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"EXISTING-SKU\",\n  \"name\": \"Product\",\n  \"price\": 10.00,\n  \"stock\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          },
          "response": [
            {
              "name": "409 Conflict",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"type\": \"https://inventory.api/problems/conflict\",\n  \"title\": \"Conflict\",\n  \"status\": 409,\n  \"detail\": \"SKU already exists: EXISTING-SKU\",\n  \"instance\": \"/api/v1/products\"\n}"
            }
          ]
        },
        {
          "name": "400 - Error de validación",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"\",\n  \"name\": \"\",\n  \"price\": -1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          },
          "response": [
            {
              "name": "400 Bad Request",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"type\": \"https://inventory.api/problems/validation-error\",\n  \"title\": \"Validation Error\",\n  \"status\": 400,\n  \"detail\": \"Validation failed\",\n  \"instance\": \"/api/v1/products\",\n  \"errors\": {\n    \"sku\": \"must not be blank\",\n    \"name\": \"must not be blank\",\n    \"price\": \"must be greater than or equal to 0.00\"\n  }\n}"
            }
          ]
        }
      ]
    }
  ]
}
