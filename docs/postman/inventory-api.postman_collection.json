    {
      "name": "Validacion de Permisos (401/403)",
      "item": [
        {
          "name": "401 - Sin token (GET productos)",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "noauth"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            },
            "description": "Sin Authorization header — debe retornar 401"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"returns 401 Unauthorized\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "pm.test(\"response has WWW-Authenticate header\", function () {",
                  "    pm.response.to.have.header(\"WWW-Authenticate\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "401 - Sin token (GET stock movements)",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "noauth"
            },
            "url": {
              "raw": "{{baseUrl}}/stock/movements",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "stock",
                "movements"
              ]
            },
            "description": "Sin Authorization header en endpoint de stock — debe retornar 401"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"returns 401 Unauthorized\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "403 - Token sin scope product:manage (POST producto)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{viewer_token}}",
                "description": "Token de inv_viewer — solo tiene scopes de lectura"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"TEST-403\",\n  \"name\": \"Test 403\",\n  \"price\": 1.0,\n  \"stock\": 0,\n  \"minimumStock\": 0,\n  \"categoryId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            },
            "description": "Token de viewer sin scope product:manage — debe retornar 403"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"returns 403 Forbidden\", function () {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "pm.test(\"not 401 (token is valid, scope is missing)\", function () {",
                  "    pm.response.to.not.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
