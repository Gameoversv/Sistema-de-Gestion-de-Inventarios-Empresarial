{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "uid": "inventory-negocio",
  "title": "3 · Negocio",
  "description": "Inventario medido como negocio, no como tráfico HTTP: movimientos confirmados por tipo, unidades que entran y salen, y qué productos cruzan su mínimo. Todas las series salen de contadores propios que solo se incrementan tras el commit de la transacción, así que un movimiento revertido no aparece aquí.",
  "tags": ["inventory", "negocio"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Situación actual",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Productos activos en el mínimo o por debajo, ahora mismo. Cualquier valor por encima de cero es una reposición pendiente: es la expresión de la alerta ProductosBajoMinimo.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto", "graphMode": "area" },
      "title": "Productos bajo mínimo",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "inventory_products_below_minimum",
        "legendFormat": "bajo mínimo",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Movimientos confirmados en el rango seleccionado, por tipo.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "value_and_name", "orientation": "horizontal" },
      "title": "Movimientos por tipo (rango)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (type) (increase(inventory_stock_movements_total[$__range]))",
        "legendFormat": "{{type}}",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Unidades que entraron y salieron en el rango. Un saldo negativo sostenido —más OUT que IN— es consumo sin reposición.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "value_and_name", "orientation": "horizontal" },
      "title": "Unidades movidas (rango)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (type) (increase(inventory_stock_units_total[$__range]))",
        "legendFormat": "{{type}}",
        "refId": "A"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "Evolución",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Ritmo de movimientos por tipo. IN es reposición, OUT es consumo y ADJUSTMENT es corrección de inventario: tres operaciones de negocio distintas que el tráfico HTTP no distingue.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 70, "lineWidth": 1, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "title": "Movimientos por tipo",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (type) (increase(inventory_stock_movements_total[5m]))",
        "legendFormat": "{{type}}",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Unidades movidas frente al número de productos bajo mínimo. Sirve para ver si las salidas están arrastrando el inventario por debajo del umbral.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "title": "Unidades movidas y productos bajo mínimo",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (type) (increase(inventory_stock_units_total[5m]))",
          "legendFormat": "unidades {{type}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "inventory_products_below_minimum",
          "legendFormat": "productos bajo mínimo",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Alertas de stock",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Qué productos cruzaron su mínimo y cuántas veces. Un SKU que reaparece aquí una y otra vez tiene el mínimo mal calibrado o un proveedor que no cumple.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-YlRd" },
          "custom": { "align": "auto" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "title": "Cruces de mínimo por SKU (top 10)",
      "type": "bargauge",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "topk(10, sum by (sku) (inventory_stock_alerts_total))",
        "legendFormat": "{{sku}}",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Acumulado por SKU: cada escalón es un cruce de mínimo, y su posición en el eje X es el momento en que ocurrió. Se muestra el contador en bruto y no un increase() a propósito: el contador de un SKU nace cuando cruza su mínimo por primera vez, y sobre una serie recién aparecida increase() devuelve cero porque Prometheus nunca observó el valor anterior. Con el acumulado, el primer cruce —el más interesante— sí se ve.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 15, "lineWidth": 2, "showPoints": "always" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["max"] }, "tooltip": { "mode": "multi" } },
      "title": "Cruces de mínimo acumulados por SKU",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (sku) (inventory_stock_alerts_total)",
        "legendFormat": "{{sku}}",
        "refId": "A"
      }]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
