{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "uid": "inventory-aplicacion",
  "title": "2 · Aplicación",
  "description": "Las cuatro señales doradas de la API: throughput, latencia, errores y saturación (pool de conexiones y JVM). Los logs del final están correlacionados con las trazas: cada línea enlaza con su traza en Tempo por el traceId.",
  "tags": ["inventory", "aplicacion"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Tráfico, latencia y errores",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" },
      "title": "Throughput",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(http_server_requests_seconds_count[5m]))",
        "legendFormat": "req/s",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Umbral en 500 ms, el mismo de la alerta LatenciaAlta.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "red", "value": 0.5 }
          ]},
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 5, "x": 5, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto" },
      "title": "Latencia p95",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))",
        "legendFormat": "p95",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Proporción de 5xx sobre el total. Umbral en 5%, el mismo de la alerta ErrorRateElevado. El 'or vector(0)' del numerador evita que el panel salga vacío cuando no hay ningún 5xx, que es el caso sano: sin él, sum() sobre un conjunto vacío no devuelve serie y el stat no muestra nada.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]},
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 5, "w": 5, "x": 10, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "auto" },
      "title": "Error rate (5xx)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "(sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) or vector(0)) / sum(rate(http_server_requests_seconds_count[5m]))",
        "legendFormat": "5xx",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 15, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "auto" },
      "title": "Uptime del backend",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "process_uptime_seconds{job=\"inventory-backend\"}",
        "legendFormat": "uptime",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Porcentaje del heap en uso.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.75 },
            { "color": "red", "value": 0.9 }
          ]},
          "unit": "percentunit", "max": 1, "min": 0
        }
      },
      "gridPos": { "h": 5, "w": 5, "x": 19, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "title": "Heap JVM",
      "type": "gauge",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(jvm_memory_used_bytes{job=\"inventory-backend\",area=\"heap\"}) / sum(jvm_memory_max_bytes{job=\"inventory-backend\",area=\"heap\"})",
        "legendFormat": "heap",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Las rutas más lentas. Es el panel al que se salta desde la alerta LatenciaAlta.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["max"] }, "tooltip": { "mode": "multi" } },
      "title": "Latencia p95 por endpoint",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "topk(8, histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket[5m]))))",
        "legendFormat": "{{uri}}",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Peticiones por código de respuesta. Separa un pico de tráfico legítimo de una avería.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "stacking": { "mode": "normal" } },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "title": "Peticiones por código de estado",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (status) (rate(http_server_requests_seconds_count[5m]))",
        "legendFormat": "{{status}}",
        "refId": "A"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 101,
      "title": "Saturación",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Si 'pendientes' se despega de cero, el cuello de botella es la base de datos y no la aplicación.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "title": "Pool HikariCP",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_active",
          "legendFormat": "activas",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_idle",
          "legendFormat": "ociosas",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_pending",
          "legendFormat": "pendientes",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Tiempo de pausa por GC y hilos vivos. Pausas crecientes con heap alto anticipan un OutOfMemory.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "title": "GC y hilos",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (cause) (rate(jvm_gc_pause_seconds_sum{job=\"inventory-backend\"}[5m]))",
          "legendFormat": "GC {{cause}} (s/s)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_threads_live_threads{job=\"inventory-backend\"}",
          "legendFormat": "hilos vivos",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Logs correlacionados",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Logs del backend en WARN y ERROR. En los perfiles staging y prod cada línea trae traceId, spanId, correlationId, usuario y endpoint, y el derived field del datasource enlaza con la traza en Tempo.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 23 },
      "id": 10,
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "title": "Backend — WARN y ERROR",
      "type": "logs",
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "{service=\"backend\"} |~ \"(?i)warn|error\"",
        "refId": "A"
      }]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
