{
  "realm": "inventory",
  "enabled": true,
  "displayName": "Inventory Management System",
  "sslRequired": "external",
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespanEnabled": false,
  "defaultSignatureAlgorithm": "RS256",
  "revokeRefreshToken": false,
  "refreshTokenMaxReuse": 0,

  "roles": {
    "realm": [
      {
        "id": "a1b2c3d4-e5f6-4000-b001-000000000001",
        "name": "inventory-admin",
        "description": "Full administrator access to the inventory system",
        "composite": false,
        "clientRole": false,
        "containerId": "inventory"
      },
      {
        "id": "a1b2c3d4-e5f6-4000-b001-000000000002",
        "name": "warehouse-clerk",
        "description": "Manage products and stock movements",
        "composite": false,
        "clientRole": false,
        "containerId": "inventory"
      },
      {
        "id": "a1b2c3d4-e5f6-4000-b001-000000000003",
        "name": "auditor",
        "description": "View reports and audit logs",
        "composite": false,
        "clientRole": false,
        "containerId": "inventory"
      },
      {
        "id": "a1b2c3d4-e5f6-4000-b001-000000000004",
        "name": "viewer",
        "description": "Read-only access to products and stock",
        "composite": false,
        "clientRole": false,
        "containerId": "inventory"
      }
    ]
  },

  "clients": [
    {
      "id": "b1b2c3d4-e5f6-4000-b002-000000000001",
      "clientId": "inventory-backend",
      "name": "Inventory Backend API",
      "description": "Spring Boot resource server — validates bearer tokens only",
      "enabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "inv-backend-secret-changeme-dev",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "nodeReRegistrationTimeout": -1,
      "defaultClientScopes": [
        "web-origins", "acr", "roles", "profile", "email"
      ],
      "optionalClientScopes": [
        "address", "phone", "offline_access", "microprofile-jwt"
      ]
    },
    {
      "id": "b1b2c3d4-e5f6-4000-b002-000000000002",
      "clientId": "inventory-frontend",
      "name": "Inventory Frontend SPA",
      "description": "React SPA — public client with PKCE",
      "enabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "nodeReRegistrationTimeout": -1,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000",
        "+"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      },
      "defaultClientScopes": [
        "web-origins", "acr", "roles", "profile", "email"
      ],
      "optionalClientScopes": [
        "address", "phone", "offline_access", "microprofile-jwt",
        "product:view", "product:manage",
        "stock:view", "stock:manage",
        "report:view", "user:manage", "audit:view"
      ]
    }
  ]
}
